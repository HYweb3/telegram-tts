{
  "name": "telegram-tts",
  "version": "1.0.0",
  "description": "Text-to-speech with automatic Telegram voice message delivery",
  "author": "openclaw",
  "license": "MIT",
  "keywords": ["tts", "telegram", "voice", "speech", "edge-tts"],
  "repository": {
    "type": "git",
